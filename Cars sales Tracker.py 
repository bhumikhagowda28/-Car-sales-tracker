car_sales = {
    "Maruti Suzuki": 120,
    "Hyundai": 95,
    "Tata Motors": 80,
    "Mahindra": 60,
    "Honda": 40,
    "Toyota": 55
}

def total_sales(): 
  return sum(car_sales.values())

def sales_by_model(model): 
  return car_sales.get (model, "Model not found")

def best_selling_car():
  return max(car_sales, 
key=car_sales.get)

# Menu-driven program
while True:
    print("\nCar Sales Tracker")
    print("1. View Total Sales")
    print("2. View Sales by Car Model")
    print("3. View Best-Selling Car")
    print("4. Exit")

    choice = input("Enter your choice (1-4): ")

    if choice == "1":
        print("Total Sales:", total_sales())
    elif choice == "2":
        model = input("Enter car model name: ")
        print("Sales for", model, ":", sales_by_model(model))
    elif choice == "3":
        print("Best-Selling Car:", best_selling_car())
    elif choice == "4":
        print("Exiting program...")
        break
    else:
        print("Invalid choice. Please try again.")