car_sales = {
    "Maruti Suzuki": 120,
    "Hyundai": 95,
    "Tata Motors": 80,
    "Mahindra": 60,
    "Honda": 40,
    "Toyota": 55
}

def total_sales(): return sum(car_sales.values())

def sales_by_model(model): return car_sales.get (model, "Model not found")

def best_selling_car(): return max(car_sales, key=car_sales.get)